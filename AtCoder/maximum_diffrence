#include <bits/stdc++.h>
using namespace std;

int main () {
  int n;
  cin >> n;
  vector<int> a(n);
  for (int i = 0;i < n;i++) cin >> a[i];
  int max = INT_MIN;
  for (int i = 0;i < n;i++) {
    for (int j = i+1;j < n;j++) {
      if (abs(a[i] - a[j]) > max) max = abs(a[i] - a[j]);
    }
  }
  cout << max << endl;
}
